# Copy this file to .env and fill in your values
# Never commit .env to git

# Cloudflare Account ID — found at dash.cloudflare.com (right sidebar)
CF_ACCOUNT_ID=your_account_id_here

# Cloudflare API Token — create at dash.cloudflare.com/profile/api-tokens
# Permissions needed: D1:Edit
CF_API_TOKEN=your_api_token_here

# D1 Database ID — shown after running: npx wrangler d1 create market-hub-db
CF_D1_DB_ID=your_d1_database_id_here

# FRED API Key — free key at https://fred.stlouisfed.org/docs/api/api_key.html
# Required for seed_buffett.py
FRED_API_KEY=your_fred_api_key_here
